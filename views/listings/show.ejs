<% layout("/layouts/boilerplate") %>
<script>
    const mapToken = "<%= process.env.MAP_TOKEN %>";
    const listing = <%- JSON.stringify(listing) %>;
</script>
<div class="row mt-5">
    <div class="col-6 offset-3">

        <h2 class="mb-2"><%= listing.title %></h2>
        <p class="text-muted mb-3 fs-5" style="font-style: italic;">
            Hosted by <%= listing.owner.username %>
        </p>
        <!-- Card -->
        <div class="card show-card listing-card">

            <!-- Image -->
            <img 
                src="<%= listing.image?.url || listing.image %>" 
                class="card-img-top show-img" 
                alt="listing-image"
            >

            <!-- Body -->
            <div class="card-body">
                <p class="card-text"><%= listing.description %></p>

                <p class="mb-1">
                    <b>&#8377; <%= listing.price.toLocaleString("en-IN") %></b> / night
                </p>

                <p class="text-muted mb-0">
                    <%= listing.location %>, <%= listing.country %>
                </p>
            </div>

        </div>
            

        <!-- Buttons -->
         <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
        <div class="mt-1 d-flex gap-2 ft">

            <a href="/listings/<%= listing._id %>/edit" class="btn btn-danger">
                Edit
            </a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
                <button class="btn btn-dark">Delete</button>
            </form>

        </div>
        <% } %>

    </div>
    <div class="col-6 offset-3">
        <% if(currUser) { %>
        <hr>
        <h4>Leave a Review</h4>
        <form action="/listings/<%=listing._id%>/reviews" method="POST" novalidate class="needs-validation">
            <div class="col-6 offset-4">
            <fieldset class="starability-slot">
                <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                <label for="first-rate1" title="Terrible">1 star</label>
                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                <label for="first-rate2" title="Not good">2 stars</label>
                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                <label for="first-rate3" title="Average">3 stars</label>
                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                <label for="first-rate4" title="Very good">4 stars</label>
                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
            </div>
            <div>
                <label for="comment" class="form-label">Comment</label>
                <textarea name="review[comment]" id="comment" class="form-control" required></textarea>
                <div class="invalid-feedback">Please give us some review</div>
            </div>
            <br>
            <button class="btn btn-danger mt-1 d-flex gap-2 ft">Submit</button>
            <br>
        </form>
        <% } %>
        <hr>
        <% if(listing.reviews.length > 0) { %>
        <div class="row">
            <h4>All Reviews</h4>
            <% if (listing.reviews.length === 0) { %>
            <p>Please share your review</p>
            <% }%>
            <% for(review of listing.reviews) { %>
                <div class="card col-5 ms-2 mb-3">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start">

                        <!-- LEFT SIDE -->
                        <div>
                            <p class="text-muted mb-1" style="font-style: italic;">
                                by <%= review.author.username %>
                            </p>

                            <p class="starability-result mb-2" 
                            data-rating="<%= review.rating %>" 
                            style="font-size: 0.8rem;">
                            </p>
                        </div>

                        <!-- RIGHT SIDE (DELETE BUTTON) -->
                        <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                            <button class="btn btn-sm p-0 border-0">
                                <i class="fa-solid fa-trash-can"></i>
                            </button>
                        </form>

                    </div>

                <p class="card-text"><%= review.comment %></p>

            </div>
        </div>
        <% } %>
        </div>
        <hr>
        <% } %>
    </div>
    <div class="col-6 offset-3 mb-4">
            <h4>Where you'll be</h4>
            <div id="map">
            </div>
    </div>
</div>

<script src="/js/map.js"></script>